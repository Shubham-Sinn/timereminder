{
  "manifest_version": 3,
  "name": "Time Reminder",
  "version": "1.2",
  "description": "Tracks usage of targeted websites, blocks after a configured time limit.",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Time Reminder",
    "default_popup": "popup.html"
  }
}
